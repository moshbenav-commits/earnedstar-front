DATABASE_URL=
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# CORS
CORS_ORIGIN=http://localhost:3000,https://earnedstar.com,https://www.earnedstar.com,https://earnedstar.vercel.app

# Auth — dev bypass when Supabase not wired (never in production)
# EARNEDSTAR_AUTH_DEV_BYPASS=1

# Invitations email — Mail Gorilla–compatible SMTP (recommended; same pattern as expedia-parts-back)
# Create mailbox invitations@earnedstar.com (Proton Mail Business or Google Workspace)
SMTP_HOST=smtp.protonmail.ch
SMTP_PORT=587
SMTP_USER=invitations@earnedstar.com
SMTP_PASS=
SMTP_FROM=EarnedStar Invitations <invitations@earnedstar.com>
SMTP_REPLY_TO=support@earnedstar.com
EARNEDSTAR_SITE_URL=https://earnedstar.com

# Optional Resend fallback (leave empty if using SMTP only)
# RESEND_API_KEY=
# RESEND_FROM=EarnedStar <invitations@earnedstar.com>

# SMS invitations (Telnyx — Growth plan+)
TELNYX_API_KEY=
TELNYX_SMS_FROM_NUMBER=
# TELNYX_MESSAGING_PROFILE_ID=
EARNEDSTAR_WEBHOOK_SECRET=

# Authorize.net ARB billing
AUTHNET_API_LOGIN_ID=
AUTHNET_TRANSACTION_KEY=
AUTHNET_PUBLIC_CLIENT_KEY=
AUTHNET_ENV=sandbox
# EARNEDSTAR_BILLING_DEV_BYPASS=1

# EarnedStar front → earnedstar-back API
NEXT_PUBLIC_API_URL=https://earnedstar-back.vercel.app/api
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Supabase Auth (project ppnbpblnuxbihhxgozxi)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Local dev without Supabase — allows /dashboard without login
# EARNEDSTAR_AUTH_DEV_BYPASS=1

# Authorize.net Accept.js (public keys — also served from back /billing/public-config)
# NEXT_PUBLIC_AUTHNET_API_LOGIN_ID=
# NEXT_PUBLIC_AUTHNET_PUBLIC_CLIENT_KEY=
# NEXT_PUBLIC_AUTHNET_ENV=sandbox

# GlitchTip (Sentry-compatible) — docs/fleet/GLITCHTIP_DSN_WIRING.md
# SENTRY_DSN=https://YOUR_PUBLIC_KEY@your-tailscale-or-tunnel-host:8000/PROJECT_ID
# SENTRY_ENVIRONMENT=development

# Payments gate — docs/fleet/PAYMENTS_INACTIVE.md (off until Auth.net prod verified)
# NEXT_PUBLIC_PAYMENTS_ENABLED=false
# PAYMENTS_ENABLED=false

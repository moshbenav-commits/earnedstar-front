{
  "name": "earnedstar",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "smoke": "bash scripts/smoke.sh",
    "smoke:prod": "SMOKE_FRONT_URL=https://earnedstar.vercel.app SMOKE_CUSTOM_DOMAIN=https://earnedstar.com SMOKE_API_URL=https://earnedstar-back.vercel.app/api bash scripts/smoke.sh",
    "audit:vercel-billing": "node scripts/vercel-billing-guard.mjs",
    "audit:vercel-billing:ci": "node scripts/vercel-billing-guard.mjs --ci",
    "deploy:prod": "bash scripts/deploy-vercel.sh",
    "deploy:prod:skip-smoke": "SKIP_POST_DEPLOY_SMOKE=1 bash scripts/deploy-vercel.sh",
    "qa:design-lab:baseline": "node scripts/design-lab-visual.mjs --update",
    "qa:design-lab:visual": "node scripts/design-lab-visual.mjs",
    "qa:design-lab:visual:strict": "node scripts/design-lab-visual.mjs --strict",
    "qa:design-lab:ci": "npm run qa:design-lab:visual",
    "mobile:sync": "npx cap sync",
    "mobile:add:ios": "npx cap add ios",
    "mobile:add:android": "npx cap add android",
    "mobile:ios": "npx cap open ios",
    "mobile:android": "npx cap open android"
  },
  "dependencies": {
    "@expedia/design-lab": "file:./packages/expedia-design-lab",
    "@expedia/design-system": "file:./packages/expedia-design-system",
    "@supabase/ssr": "^0.12.0",
    "@supabase/supabase-js": "^2.108.2",
    "clsx": "^2.1.1",
    "framer-motion": "^12.40.0",
    "lucide-react": "^1.18.0",
    "next": "16.2.9",
    "qrcode": "^1.5.4",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-icons": "^5.5.0",
    "recharts": "^3.8.1",
    "tailwind-merge": "^3.6.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@capacitor/android": "^7.6.7",
    "@capacitor/cli": "^7.6.7",
    "@capacitor/core": "^7.6.7",
    "@capacitor/ios": "^7.6.7",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
